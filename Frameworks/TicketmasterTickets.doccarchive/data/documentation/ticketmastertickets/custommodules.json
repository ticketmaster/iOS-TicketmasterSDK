{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/CustomModules"},"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets"]]},"abstract":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule","type":"reference","isActive":true},{"text":" is defined by three values:","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"A unique identifier string"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional Header View"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"0 to 3 Buttons","type":"text"}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"See: "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/init(identifier:headerDisplay:actionButtons:)"}],"type":"paragraph"},{"inlineContent":[{"text":"Modules are built and returned in ","type":"text"},{"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleDelegate\/addCustomModules(event:completion:)","isActive":true,"type":"reference"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["extension MyClass: TMTicketsModuleDelegate {    ","","    func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","        \/\/ build a UIView","        let view = UIView()","        view.backgroundColor = .red","    ","        \/\/ build Header with UIView","        let header = TMTicketsModule.HeaderDisplay(view: view)","    ","        \/\/ build buttons","        let button1 = TMTicketsModule.ActionButton(title: \"One\")","        let button2 = TMTicketsModule.ActionButton(title: \"Two\")","        let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","        \/\/ build module with header and buttons","        let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                    headerDisplay: header,","                                    actionButtons: [button1, button2, button3])","    ","        \/\/ return modules in display order","        completion([module])","    }","}"]},{"inlineContent":[{"text":"Output:","type":"text"},{"text":" ","type":"text"},{"identifier":"Module_DefaultAspect.jpg","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Let’s examine each of these three values in detail."}],"type":"paragraph"},{"text":"Identifier","level":2,"type":"heading","anchor":"Identifier"},{"inlineContent":[{"type":"text","text":"A globally unique indentifier is best to avoid conflicts with any internal or pre-built module names."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"We recommend using a reverse URL style."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unique examples:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"“com.ticketmaster.seatUpgrades”","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“com.nfl.broncosSeating”"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"“com.myDemoApp.demoModule”"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Header","anchor":"Header"},{"type":"paragraph","inlineContent":[{"type":"text","text":"While optional, the Header is the most easily visible component of a Module."}]},{"type":"paragraph","inlineContent":[{"text":"A Header (","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/HeaderDisplay-swift.class"},{"type":"text","text":") is simply a wrapper around a UIView."}]},{"type":"paragraph","inlineContent":[{"text":"Note that a Module can contain a Header with no Buttons, or Buttons with no Header.","type":"text"}]},{"type":"heading","text":"Size","anchor":"Size","level":3},{"type":"paragraph","inlineContent":[{"text":"The Header is automatically resized to the width of the user’s phone, so you can only really control the height. This is done by setting an aspect ratio.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The default aspect ratio (3x2) is recommended for visual consistancy.","type":"text"}]},{"type":"heading","text":"Header Default Aspect Ratio","anchor":"Header-Default-Aspect-Ratio","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Build a module with a Red header, using the default aspect ratio (3x2).","type":"text"}]}]}]},{"type":"codeListing","syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with default aspect ratio 3x2)","    let view = UIView()","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Output:","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"Module_DefaultAspect.jpg"}]},{"type":"heading","text":"Header Custom Aspect Ratio","anchor":"Header-Custom-Aspect-Ratio","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Header inherits it’s aspect ratio from the provided UIView, so by setting the size of the UIView you can alter the aspect ratio of the Header."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Build a module with a Red header, using a custom defined aspect ratio (1x1).","type":"text"}]}]}]},{"type":"codeListing","syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with a defined aspect ratio)","    let view = UIView(frame: CGRect(x: 0, y: 0, width: 1, height: 1))","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"identifier":"Module_DefinedAspect.jpg","type":"image"}]},{"type":"heading","text":"Custom Header Image","anchor":"Custom-Header-Image","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Headers can also be created with a UIImage (as a convenience). The aspect ratio of the Header is inherited from the size of the UIImage."}]},{"items":[{"content":[{"inlineContent":[{"text":"Build a module with an Image header, aspect ratio is defined by Image size:","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ load UIImage","    let image = UIImage(imageLiteralResourceName: \"HotDogs.jpg\")","    ","    \/\/ build header with UIImage","    let header = TMTicketsModule.HeaderDisplay(image: image)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"],"syntax":null,"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_Image.jpg","type":"image"}],"type":"paragraph"},{"level":2,"text":"HeaderView Builder","anchor":"HeaderView-Builder","type":"heading"},{"inlineContent":[{"type":"text","text":"While you are welcome to build a Header using any UIView, a helpful Header builder has been provided."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleHeaderView","isActive":true,"type":"reference"},{"text":" can help you quickly build a UIView for presentation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"TMTicketsModuleHeaderView\/configure(topLabelText:topLabelTextAlignment:topLabelTextColor:centerLabelText:centerLabelTextAlignment:centerLabelTextColor:bottomLabelText:bottomLabelTextAlignment:bottomLabelTextColor:titleLabelText:titleLabelTextColor:messageLabelText:messageLabelTextColor:messageLabelDetectLinks:messageLabelLinkColor:titleMessageBackgroundColor:gradientAlpha:backgroundAspectRatio:backgroundAspectRatioForced:backgroundColor:backgroundImage:backgroundImageURL:mapCoordinateRegion:mapAnnotation:avContentURL:disableLoopingContent:disableAVAudio:barcode2DValue:qrCodeValue:aztecValue:pdf417Value:headerOverride:)"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The header builder supports custom content:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"UIColor background","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["headerView.configure(..., backgroundColor:)"],"syntax":null,"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"UIImage background"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["headerView.configure(..., backgroundImage:)"],"syntax":null,"type":"codeListing"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"UIImageURL background","type":"text"}]}]}],"type":"unorderedList"},{"syntax":null,"type":"codeListing","code":["headerView.configure(..., backgroundImageURL:)"]},{"items":[{"content":[{"inlineContent":[{"text":"MKCoordinateRegion map","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"type":"codeListing","code":["headerView.configure(..., mapCoordinateRegion:mapAnnotation:)"]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"2D Barcode"}]}]}],"type":"unorderedList"},{"syntax":null,"type":"codeListing","code":["headerView.configure(..., barcode2DValue:)"]},{"items":[{