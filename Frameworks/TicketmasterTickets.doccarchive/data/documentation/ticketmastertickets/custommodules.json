{"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"TicketmasterTickets"}],"title":"Custom Module"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule"},{"type":"text","text":" is defined by three values:"}],"variants":[{"paths":["\/documentation\/ticketmastertickets\/custommodules"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/ticketmastertickets\/custommodules"]}],"kind":"article","identifier":{"url":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/CustomModules","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"items":[{"content":[{"inlineContent":[{"text":"A unique identifier string","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"An optional Header View","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0 to 3 Buttons"}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"See: "},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/init(identifier:headerDisplay:actionButtons:)","type":"reference"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Modules are built and returned in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleDelegate\/addCustomModules(event:completion:)"}],"type":"paragraph"},{"type":"codeListing","code":["extension MyClass: TMTicketsModuleDelegate {    ","","    func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","        \/\/ build a UIView","        let view = UIView()","        view.backgroundColor = .red","    ","        \/\/ build Header with UIView","        let header = TMTicketsModule.HeaderDisplay(view: view)","    ","        \/\/ build buttons","        let button1 = TMTicketsModule.ActionButton(title: \"One\")","        let button2 = TMTicketsModule.ActionButton(title: \"Two\")","        let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","        \/\/ build module with header and buttons","        let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                    headerDisplay: header,","                                    actionButtons: [button1, button2, button3])","    ","        \/\/ return modules in display order","        completion([module])","    }","}"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"Output:","type":"text"},{"text":" ","type":"text"},{"type":"image","identifier":"Module_DefaultAspect.jpg"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s examine each of these three values in detail."}]},{"level":2,"text":"Identifier","anchor":"Identifier","type":"heading"},{"inlineContent":[{"type":"text","text":"A globally unique indentifier is best to avoid conflicts with any internal or pre-built module names."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"We recommend using a reverse URL style."}]},{"inlineContent":[{"text":"Unique examples:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"“com.ticketmaster.seatUpgrades”"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"“com.nfl.broncosSeating”","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"“com.myDemoApp.demoModule”","type":"text"}]}]}]},{"type":"heading","text":"Header","anchor":"Header","level":2},{"inlineContent":[{"type":"text","text":"While optional, the Header is the most easily visible component of a Module."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A Header ("},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/HeaderDisplay-swift.class"},{"text":") is simply a wrapper around a UIView.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that a Module can contain a Header with no Buttons, or Buttons with no Header.","type":"text"}]},{"text":"Size","level":3,"anchor":"Size","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The Header is automatically resized to the width of the user’s phone, so you can only really control the height. This is done by setting an aspect ratio.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The default aspect ratio (3x2) is recommended for visual consistancy."}],"type":"paragraph"},{"text":"Header Default Aspect Ratio","type":"heading","anchor":"Header-Default-Aspect-Ratio","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Build a module with a Red header, using the default aspect ratio (3x2).","type":"text"}]}]}]},{"syntax":null,"type":"codeListing","code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with default aspect ratio 3x2)","    let view = UIView()","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")",""," 