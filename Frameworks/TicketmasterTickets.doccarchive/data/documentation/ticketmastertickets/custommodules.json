{"abstract":[{"text":"A ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule","isActive":true},{"text":" is defined by three values:","type":"text"}],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ticketmastertickets\/custommodules"]},{"paths":["\/documentation\/ticketmastertickets\/custommodules"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"roleHeading":"Article","modules":[{"name":"TicketmasterTickets"}],"title":"Custom Module","role":"article"},"sections":[],"primaryContentSections":[{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"A unique identifier string"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"An optional Header View"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"0 to 3 Buttons"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"text":"See: ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/init(identifier:headerDisplay:actionButtons:)","type":"reference"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Modules are built and returned in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleDelegate\/addCustomModules(event:completion:)","type":"reference"}]},{"syntax":null,"code":["extension MyClass: TMTicketsModuleDelegate {    ","","    func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","        \/\/ build a UIView","        let view = UIView()","        view.backgroundColor = .red","    ","        \/\/ build Header with UIView","        let header = TMTicketsModule.HeaderDisplay(view: view)","    ","        \/\/ build buttons","        let button1 = TMTicketsModule.ActionButton(title: \"One\")","        let button2 = TMTicketsModule.ActionButton(title: \"Two\")","        let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","        \/\/ build module with header and buttons","        let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                    headerDisplay: header,","                                    actionButtons: [button1, button2, button3])","    ","        \/\/ return modules in display order","        completion([module])","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Output:","type":"text"},{"text":" ","type":"text"},{"identifier":"Module_DefaultAspect.jpg","type":"image"}]},{"inlineContent":[{"type":"text","text":"Let’s examine each of these three values in detail."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Identifier","anchor":"Identifier"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A globally unique indentifier is best to avoid conflicts with any internal or pre-built module names."}]},{"inlineContent":[{"type":"text","text":"We recommend using a reverse URL style."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Unique examples:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"“com.ticketmaster.seatUpgrades”"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"“com.nfl.broncosSeating”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"“com.myDemoApp.demoModule”"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Header","type":"heading","level":2,"text":"Header"},{"type":"paragraph","inlineContent":[{"text":"While optional, the Header is the most easily visible component of a Module.","type":"text"}]},{"inlineContent":[{"type":"text","text":"A Header ("},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/HeaderDisplay-swift.class"},{"type":"text","text":") is simply a wrapper around a UIView."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that a Module can contain a Header with no Buttons, or Buttons with no Header.","type":"text"}]},{"text":"Size","level":3,"type":"heading","anchor":"Size"},{"type":"paragraph","inlineContent":[{"text":"The Header is automatically resized to the width of the user’s phone, so you can only really control the height. This is done by setting an aspect ratio.","type":"text"}]},{"inlineContent":[{"text":"The default aspect ratio (3x2) is recommended for visual consistancy.","type":"text"}],"type":"paragraph"},{"anchor":"Header-Default-Aspect-Ratio","type":"heading","level":2,"text":"Header Default Aspect Ratio"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build a module with a Red header, using the default aspect ratio (3x2)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with default aspect ratio 3x2)","    let view = UIView()","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_DefaultAspect.jpg","type":"image"}],"type":"paragraph"},{"anchor":"Header-Custom-Aspect-Ratio","type":"heading","level":2,"text":"Header Custom Aspect Ratio"},{"type":"paragraph","inlineContent":[{"text":"The Header inherits it’s aspect ratio from the provided UIView, so by setting the size of the UIView you can alter the aspect ratio of the Header.","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build a module with a Red header, using a custom defined aspect ratio (1x1)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"codeListing","syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with a defined aspect ratio)","    let view = UIView(frame: CGRect(x: 0, y: 0, width: 1, height: 1))","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_DefinedAspect.jpg","type":"image"}],"type":"paragraph"},{"anchor":"Custom-Header-Image","type":"heading","level":2,"text":"Custom Header Image"},{"type":"paragraph","inlineContent":[{"text":"Headers can also be created with a UIImage (as a convenience). The aspect ratio of the Header is inherited from the size of the UIImage.","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build a module with an Image header, aspect ratio is defined by Image size:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"codeListing","syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ load UIImage","    let image = UIImage(imageLiteralResourceName: \"HotDogs.jpg\")","    ","    \/\/ build header with UIImage","    let header = TMTicketsModule.HeaderDisplay(image: image)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_Image.jpg","type":"image"}],"type":"paragraph"},{"anchor":"HeaderView-Builder","type":"heading","level":2,"text":"HeaderView Builder"},{"type":"paragraph","inlineContent":[{"text":"While you are welcome to build a Header using any UIView, a helpful Header builder has been provided.","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleHeaderView","type":"reference"},{"text":" can help you quickly build a UIView for presentation.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"TMTicketsModuleHeaderView\/configure(topLabelText:topLabelTextAlignment:topLabelTextColor:centerLabelText:centerLabelTextAlignment:centerLabelTextColor:bottomLabelText:bottomLabelTextAlignment:bottomLabelTextColor:titleLabelText:titleLabelTextColor:messageLabelText:messageLabelTextColor:messageLabelDetectLinks:messageLabelLinkColor:titleMessageBackgroundColor:gradientAlpha:backgroundAspectRatio:backgroundAspectRatioForced:backgroundColor:backgroundImage:backgroundImageURL:mapCoordinateRegion:mapAnnotation:avContentURL:disableLoopingContent:disableAVAudio:barcode2DValue:qrCodeValue:aztecValue:pdf417Value:headerOverride:)","type":"codeVoice"}]},{"inlineContent":[{"text":"The header builder supports custom content:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"UIColor background"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., backgroundColor:)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"UIImage background"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., backgroundImage:)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"UIImageURL background"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., backgroundImageURL:)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"MKCoordinateRegion map"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., mapCoordinateRegion:mapAnnotation:)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"2D Barcode"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., barcode2DValue:)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"QR Code"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., qrCodeValue:)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Aztec Barcode"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., aztecValue:)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"PDF417 Barcode"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., pdf417Value:)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Audio\/Video Content"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(..., avContentURL:disableLoopingContent:disableAVAudio:)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"And custom text:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Three lines of custom Text on top of content"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"codeListing","syntax":null,"code":["headerView.configure(topLabelText:topLabelTextAlignment:topLabelTextColor:centerLabelText:centerLabelTextAlignment:centerLabelTextColor:bottomLabelText:bottomLabelTextAlignment:bottomLabelTextColor: ...)"]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Title and Message custom Text underneath content"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["headerView.configure(titleLabelText:titleLabelTextColor:messageLabelText:messageLabelTextColor:messageLabelDetectLinks:messageLabelLinkColor:titleMessageBackgroundColor: ...)"],"type":"codeListing"},{"anchor":"HeaderView-Builder-Color","type":"heading","level":2,"text":"HeaderView Builder: Color"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build a module with a Red header, using the Header View builder:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with default aspect ratio 3x2)","    let headerView = TMTicketsModuleHeaderView.build()","    headerView.configure(topLabelText: \"Red is great!\", backgroundColor: .red)","    ","    \/\/ build header with HeaderView (a UIView)","    let header = TMTicketsModule.HeaderDisplay(view: headerView)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_DefaultAspect.jpg","type":"image"}],"type":"paragraph"},{"anchor":"HeaderView-Builder-Image-+-Text-+-Gradient","type":"heading","level":2,"text":"HeaderView Builder: Image + Text + Gradient"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build a module with an Image, Text, and Gradient:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ load UIImage","    let image = UIImage(imageLiteralResourceName: \"HotDogs.jpg\")","    ","    \/\/ build a UIView with a text, gradient, and image","    let headerView = TMTicketsModuleHeaderView.build()","    headerView.configure(topLabelText: \"Food\",","                         topLabelTextAlignment: .left,","                         centerLabelText: \"Drinks\",","                         centerLabelTextAlignment: .center,","                         bottomLabelText: \"Fun\",","                         bottomLabelTextAlignment: .right,","                         gradientAlpha: 1.0,","                         backgroundImage: image)","    ","    \/\/ build header with HeaderView (a UIView)","    let header = TMTicketsModule.HeaderDisplay(view: headerView)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_ImageText.jpg","type":"image"}],"type":"paragraph"},{"anchor":"HeaderView-Builder-Map","type":"heading","level":2,"text":"HeaderView Builder: Map"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build a module with a Map and Text:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ define map region and zoom (span)","    let mapRegion = MKCoordinateRegion(","        center: CLLocationCoordinate2D(latitude: 34.0734, longitude: -118.2402),","        span: MKCoordinateSpan(latitudeDelta: 0.02, longitudeDelta: 0.02))","    ","    \/\/ define map point of interest","    let mapAnnotation = TMTicketsModuleHeaderView.MapAnnotation(","        coordinate: CLLocationCoordinate2D(latitude: 34.0735, longitude: -118.2456),","        title: \"Lot 1\")","    ","    \/\/ build a UIView with a text, gradient, and image","    let headerView = TMTicketsModuleHeaderView.build()","    headerView.configure(topLabelText: \"Parking: Lot 1\",","                         mapCoordinateRegion: mapRegion,","                         mapAnnotation: mapAnnotation)","    ","    \/\/ build header with HeaderView (a UIView)","    let header = TMTicketsModule.HeaderDisplay(view: headerView)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_MapText.jpg","type":"image"}],"type":"paragraph"},{"anchor":"HeaderView-Builder-QR-Code","type":"heading","level":2,"text":"HeaderView Builder: QR Code"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build a module with a QR Code, Image, Gradient and Text:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView with a text, QR code, gradient, and image","    let headerView = TMTicketsModuleHeaderView.build()","    headerView.configure(topLabelText: \"Broncos Fan Voucher\",","                         bottomLabelText: \"Stored Value: $58.90\",","                         gradientAlpha: 1.0,","                         backgroundImage: UIImage(named: \"BroncosPlay.jpg\"),","                         qrCodeValue: \"1234567890ABCDEF\")","","    \/\/ build header with HeaderView (a UIView)","    let header = TMTicketsModule.HeaderDisplay(view: headerView)","","    \/\/ build module with header, but no buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: nil) \/\/ no buttons","    ","    \/\/ return module","    completion([module])","}"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_QRText.jpg","type":"image"}],"type":"paragraph"},{"anchor":"HeaderView-Builder-Video","type":"heading","level":2,"text":"HeaderView Builder: Video"},{"type":"paragraph","inlineContent":[{"text":"The video will start playing as soon as the user scrolls down to the module.","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build a module with a Video and Text:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"codeListing","syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ load video from local file or web URL","    let ticketsMovieURL = Bundle.main.url(forResource: \"BroncosMobileTickets\", withExtension: \"mp4\")!","    ","    \/\/ build a UIView with a text, QR code, and image","    let headerView = TMTicketsModuleHeaderView.build()","    headerView.configure(topLabelText: \"Entry Demo\",","                         avContentURL: ticketsMovieURL)","    ","    \/\/ build header with HeaderView (a UIView)","    let header = TMTicketsModule.HeaderDisplay(view: headerView)","","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Module_VideoText.jpg","type":"image"}],"type":"paragraph"},{"anchor":"Buttons","type":"heading","level":2,"text":"Buttons"},{"type":"paragraph","inlineContent":[{"text":"Buttons (","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/ActionButton","type":"reference"},{"text":") are assigned Actions that occur when the button is pressed.","type":"text"}]},{"inlineContent":[{"text":"Currently, only two Actions are supported:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"open a given webpage inside Tickets SDK (in a webview)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"callback to module delegate (inside your app)"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"text":"Note that a Module can contain a Header with no Buttons, or Buttons with no Header.","type":"text"}],"type":"paragraph"},{"anchor":"Button-Action-Callback","type":"heading","level":2,"text":"Button Action: Callback"},{"type":"paragraph","inlineContent":[{"text":"If webpage settings are not defined on the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/ActionButton","type":"reference"},{"text":", then when the user presses the button, the callback method on the module delegate will be called: ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleDelegate\/handleModuleActionButton(event:module:button:completion:)","type":"reference"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Build three buttons (with no header):"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"codeListing","syntax":null,"code":["extension MyClass: TMTicketsModuleDelegate {","    ","    func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","        \/\/ build buttons","        let button1 = TMTicketsModule.ActionButton(title: \"One\")","        let button2 = TMTicketsModule.ActionButton(title: \"Two\")","        let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","        \/\/ build module with header and buttons","        let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                     headerDisplay: nil, \/\/ no header","                                     actionButtons: [button1, button2, button3])","        ","        \/\/ return module","        completion([module])","    }","    ","    func handleModuleActionButton(","        event: TMPurchasedEvent,","        module: TMTicketsModule,","        button: TMTicketsModule.ActionButton,","        completion: @escaping (TMTicketsModule.WebpageSettings?) -> Void) {","","        \/\/ this is not called if webpage settings are already defined","        if module.identifier == \"com.myDemoApp.demoModule\" {","            if button.callbackValue == \"One\" {","                print(\"Action: One\")","                \/\/ handle in your own code, do not close modal Tickets Listing page ","                \/\/ do not call completion","                handle(button: button)","                ","            } else if button.callbackValue == \"Two\" {","                print(\"Action: Two\")","                \/\/ handle in your own code, but first close modal Tickets Listing page","                \/\/ call completion with nil","                completion(nil)","                handle(button: button)","","            } else if button.callbackValue == \"Three\" {","                print(\"Action: Three\")","                \/\/ open a webpage inside Tickets SDK (webview)","                let request = URLRequest(url: URL(string: \"https:\/\/www.mlb.com\")!)","                let settings = TMTicketsModule.WebpageSettings(pageTitle: \"MLB Homepage\",","                                                               urlRequest: request)","                \/\/ call completion with webpage settings","                completion(settings)","            }","        }","    }","}"]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"Button_Three.jpg","type":"image"}],"type":"paragraph"},{"text":"Button Action: Callback Completion","anchor":"Button-Action-Callback-Completion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Notice that the handleModuleActionButton delegate method has a completion closure."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This is used to inform Tickets SDK of which behavior you would like when the user presses a Module Button."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Do not close modal Tickets Listing page and handle button in your own code:","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","code":["if button.callbackValue == \"One\" {","    print(\"Action: One\")","    \/\/ handle in your own code, do not close modal Tickets Listing page ","    \/\/ do not call completion","    handle(button: button)"],"syntax":null},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Close modal Tickets Listing page first, then handle button in your own code:","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","code":["} else if button.callbackValue == \"Two\" {","    print(\"Action: Two\")","    \/\/ handle in your own code, but first close modal Tickets Listing page","    \/\/ call completion with nil","    completion(nil)","    handle(button: button)"],"syntax":null},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Do not close modal Tickets Listing page, have Tickets SDK open a webpage for you:","type":"text"}],"type":"paragraph"}]}]},{"syntax":null,"code":["} else if button.callbackValue == \"Three\" {","    print(\"Action: Three\")","    \/\/ open a webpage inside Tickets SDK (webview)","    let request = URLRequest(url: URL(string: \"https:\/\/www.mlb.com\")!)","    let settings = TMTicketsModule.WebpageSettings(pageTitle: \"MLB Homepage\",","                                                   urlRequest: request)","    \/\/ call completion with webpage settings","    completion(settings)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Output:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"identifier":"Button_MLBWebpage.jpg","type":"image"}]},{"text":"Button Action: Webpage Settings","anchor":"Button-Action-Webpage-Settings","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"You can provide the Button webpage settings ahead of time instead of waiting for the callback."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that is this case, the handleModuleActionButton delegate method will not be called.","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Build one button with pre-defined webpage settings (with no header):","type":"text"}]}]}],"type":"unorderedList"},{"type":"codeListing","syntax":null,"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build webpage settings","    let request = URLRequest(url: URL(string: \"https:\/\/www.mlb.com\")!)","    let settings = TMTicketsModule.WebpageSettings(pageTitle: \"MLB Homepage\",","                                                   urlRequest: request)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\",","                                               webpageSettings: settings)","    ","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: nil, \/\/ no header","                                 actionButtons: [button1])","    ","    \/\/ return module","    completion([module])","}"]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Output:","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"identifier":"Button_MLBWebpage.jpg","type":"image"}]},{"text":"Button Action: Webpage Settings + State","anchor":"Button-Action-Webpage-Settings-+-State","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Typically you will want to pass in some state variables to the webpage. For example, maybe which event the user is viewing.","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"This can be done with URL parameters."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"You may also want to pass values securely. For example, the user’s login state (oauth token)."}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This can be done with "},{"type":"reference","identifier":"doc:\/\/com.ticketmas