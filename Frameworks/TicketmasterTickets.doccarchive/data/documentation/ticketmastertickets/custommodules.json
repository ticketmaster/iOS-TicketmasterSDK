{"hierarchy":{"paths":[["doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","identifier":{"url":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/CustomModules","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"A "},{"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule","type":"reference","isActive":true},{"type":"text","text":" is defined by three values:"}],"sections":[],"metadata":{"title":"Custom Module","modules":[{"name":"TicketmasterTickets"}],"roleHeading":"Article","role":"article"},"variants":[{"paths":["\/documentation\/ticketmastertickets\/custommodules"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/ticketmastertickets\/custommodules"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"A unique identifier string","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"An optional Header View","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"0 to 3 Buttons","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"See: ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/init(identifier:headerDisplay:actionButtons:)","type":"reference"}]},{"type":"paragraph","inlineContent":[{"text":"Modules are built and returned in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleDelegate\/addCustomModules(event:completion:)","type":"reference"}]},{"syntax":null,"type":"codeListing","code":["extension MyClass: TMTicketsModuleDelegate {    ","","    func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","        \/\/ build a UIView","        let view = UIView()","        view.backgroundColor = .red","    ","        \/\/ build Header with UIView","        let header = TMTicketsModule.HeaderDisplay(view: view)","    ","        \/\/ build buttons","        let button1 = TMTicketsModule.ActionButton(title: \"One\")","        let button2 = TMTicketsModule.ActionButton(title: \"Two\")","        let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","        \/\/ build module with header and buttons","        let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                    headerDisplay: header,","                                    actionButtons: [button1, button2, button3])","    ","        \/\/ return modules in display order","        completion([module])","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Output:","type":"text"},{"text":" ","type":"text"},{"identifier":"Module_DefaultAspect.jpg","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Let’s examine each of these three values in detail.","type":"text"}]},{"level":2,"type":"heading","text":"Identifier","anchor":"Identifier"},{"type":"paragraph","inlineContent":[{"text":"A globally unique indentifier is best to avoid conflicts with any internal or pre-built module names.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"We recommend using a reverse URL style.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Unique examples:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"“com.ticketmaster.seatUpgrades”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"“com.nfl.broncosSeating”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"“com.myDemoApp.demoModule”","type":"text"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Header","anchor":"Header"},{"type":"paragraph","inlineContent":[{"text":"While optional, the Header is the most easily visible component of a Module.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A Header (","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/HeaderDisplay-swift.class","type":"reference"},{"text":") is simply a wrapper around a UIView.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that a Module can contain a Header with no Buttons, or Buttons with no Header.","type":"text"}]},{"level":3,"type":"heading","text":"Size","anchor":"Size"},{"type":"paragraph","inlineContent":[{"text":"The Header is automatically resized to the width of the user’s phone, so you can only really control the height. This is done by setting an aspect ratio.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The default aspect ratio (3x2) is recommended for visual consistancy.","type":"text"}]},{"level":2,"type":"heading","text":"Header Default Aspect Ratio","anchor":"Header-Default-Aspect-Ratio"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Build a module with a Red header, using the default aspect ratio (3x2).","type":"text"}],"type":"paragraph"}]}]},{"syntax":null,"type":"codeListing","code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with default aspect ratio 3x2)","    let view = UIView()","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Output:","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"identifier":"Module_DefaultAspect.jpg","type":"image"}]},{"level":2,"type":"heading","text":"Header Custom Aspect Ratio","anchor":"Header-Custom-Aspect-Ratio"},{"type":"paragraph","inlineContent":[{"text":"The Header inherits it’s aspect ratio from the provided UIView, so by setting the size of the UIView you can alter the aspect ratio of the Header.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Build a module with a Red header, using a custom defined aspect ratio (1x1).","type":"text"}],"type":"paragraph"}]}]},{"syntax":null,"type":"codeListing","code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with a defined aspect ratio)","    let view = UIView(frame: CGRect(x: 0, y: 0, width: 1, height: 1))","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Output:","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"identifier":"Module_DefinedAspect.jpg","type":"image"}]},{"level":2,"type":"heading","text":"Custom Header Image","anchor":"Custom-Header-Image"},{"type":"paragraph","inlineContent":[{"text":"Headers can also be created with a UIImage (as a convenience). The aspect ratio of the Header is inherited from the size of the UIImage.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Build a module with an Image header, aspect ratio is defined by Image size:","type":"text"}],"type":"paragraph"}]}]},{"syntax":null,"type":"codeListing","code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ load UIImage","    let image = UIImage(imageLiteralResourceName: \"HotDogs.jpg\")","    ","    \/\/ build header with UIImage","    let header = TMTicketsModule.HeaderDisplay(image: image)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Output:","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"identifier":"Module_Image.jpg","type":"image"}]},{"level":2,"type":"heading","text":"HeaderView Builder","anchor":"HeaderView-Builder"},{"type":"paragraph","inlineContent":[{"text":"While you are welcome to build a Header using any UIVie