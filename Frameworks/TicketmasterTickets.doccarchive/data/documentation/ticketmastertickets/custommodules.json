{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"text":"A ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule"},{"type":"text","text":" is defined by three values:"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/CustomModules"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ticketmastertickets\/custommodules"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/ticketmastertickets\/custommodules"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"A unique identifier string"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional Header View","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"0 to 3 Buttons","type":"text"}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See: "},{"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/init(identifier:headerDisplay:actionButtons:)","isActive":true,"type":"reference"}]},{"inlineContent":[{"type":"text","text":"Modules are built and returned in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleDelegate\/addCustomModules(event:completion:)"}],"type":"paragraph"},{"code":["extension MyClass: TMTicketsModuleDelegate {    ","","    func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","        \/\/ build a UIView","        let view = UIView()","        view.backgroundColor = .red","    ","        \/\/ build Header with UIView","        let header = TMTicketsModule.HeaderDisplay(view: view)","    ","        \/\/ build buttons","        let button1 = TMTicketsModule.ActionButton(title: \"One\")","        let button2 = TMTicketsModule.ActionButton(title: \"Two\")","        let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","        \/\/ build module with header and buttons","        let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                    headerDisplay: header,","                                    actionButtons: [button1, button2, button3])","    ","        \/\/ return modules in display order","        completion([module])","    }","}"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Output:"},{"text":" ","type":"text"},{"type":"image","identifier":"Module_DefaultAspect.jpg"}]},{"inlineContent":[{"type":"text","text":"Let’s examine each of these three values in detail."}],"type":"paragraph"},{"type":"heading","text":"Identifier","anchor":"Identifier","level":2},{"inlineContent":[{"type":"text","text":"A globally unique indentifier is best to avoid conflicts with any internal or pre-built module names."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"We recommend using a reverse URL style."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Unique examples:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"“com.ticketmaster.seatUpgrades”"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“com.nfl.broncosSeating”"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“com.myDemoApp.demoModule”"}]}]}],"type":"unorderedList"},{"anchor":"Header","text":"Header","type":"heading","level":2},{"inlineContent":[{"text":"While optional, the Header is the most easily visible component of a Module.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A Header ("},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModule\/HeaderDisplay-swift.class"},{"text":") is simply a wrapper around a UIView.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that a Module can contain a Header with no Buttons, or Buttons with no Header."}]},{"level":3,"text":"Size","anchor":"Size","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The Header is automatically resized to the width of the user’s phone, so you can only really control the height. This is done by setting an aspect ratio.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default aspect ratio (3x2) is recommended for visual consistancy."}]},{"anchor":"Header-Default-Aspect-Ratio","text":"Header Default Aspect Ratio","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Build a module with a Red header, using the default aspect ratio (3x2).","type":"text"}]}]}],"type":"unorderedList"},{"syntax":null,"type":"codeListing","code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with default aspect ratio 3x2)","    let view = UIView()","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Output:","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"Module_DefaultAspect.jpg"}]},{"type":"heading","anchor":"Header-Custom-Aspect-Ratio","text":"Header Custom Aspect Ratio","level":2},{"inlineContent":[{"type":"text","text":"The Header inherits it’s aspect ratio from the provided UIView, so by setting the size of the UIView you can alter the aspect ratio of the Header."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Build a module with a Red header, using a custom defined aspect ratio (1x1)."}]}]}]},{"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ build a UIView (with a defined aspect ratio)","    let view = UIView(frame: CGRect(x: 0, y: 0, width: 1, height: 1))","    view.backgroundColor = .red","    ","    \/\/ build header with UIView","    let header = TMTicketsModule.HeaderDisplay(view: view)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"],"syntax":null,"type":"codeListing"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Output:"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"image","identifier":"Module_DefinedAspect.jpg"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Custom Header Image","anchor":"Custom-Header-Image"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Headers can also be created with a UIImage (as a convenience). The aspect ratio of the Header is inherited from the size of the UIImage."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Build a module with an Image header, aspect ratio is defined by Image size:","type":"text"}]}]}]},{"code":["func addCustomModules(event: TMPurchasedEvent, completion: @escaping ([TMTicketsModule]?) -> Void) {","    \/\/ load UIImage","    let image = UIImage(imageLiteralResourceName: \"HotDogs.jpg\")","    ","    \/\/ build header with UIImage","    let header = TMTicketsModule.HeaderDisplay(image: image)","    ","    \/\/ build buttons","    let button1 = TMTicketsModule.ActionButton(title: \"One\")","    let button2 = TMTicketsModule.ActionButton(title: \"Two\")","    let button3 = TMTicketsModule.ActionButton(title: \"Three\")","","    \/\/ build module with header and buttons","    let module = TMTicketsModule(identifier: \"com.myDemoApp.demoModule\",","                                 headerDisplay: header,","                                 actionButtons: [button1, button2, button3])","    ","    \/\/ return module","    completion([module])","}"],"syntax":null,"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"text":"Output:","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"identifier":"Module_Image.jpg","type":"image"}]},{"anchor":"HeaderView-Builder","text":"HeaderView Builder","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"While you are welcome to build a Header using any UIView, a helpful Header builder has been provided."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.ticketmaster.TicketmasterTickets\/documentation\/TicketmasterTickets\/TMTicketsModuleHeaderView","isActive":true},{"type":"text","text":" can help you quickly build a UIView for presentation."}]},{"inlineContent":[{"code":"TMTicketsModuleHeaderView\/configure(topLabelText:topLabelTextAlignment:topLabelTextColor:centerLabelText:centerLabelTextAlignment:centerLabelTextColor:bottomLabelText:bottomLabelTextAlignment:bottomLabelTextColor:titleLabelText:titleLabelTextColor:messageLabelText:messageLabelTextColor:messageLabelDetectLinks:messageLabelLinkColor:titleMessageBackgroundColor:gradientAlpha:backgroundAspectRatio:backgroundAspectRatioForced:backgroundColor:backgroundImage:backgroundImageURL:mapCoordinateRegion:mapAnnotation:avContentURL:disableLoopingContent:disableAVAudio:barcode2DValue:qrCodeValue:aztecValue:pdf417Value:headerOverride:)","type":"codeVoice"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The header builder supports custom content:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"UIColor background"}]}]}]},{"syntax":null,"type":"codeListing","code":["headerView.configure(..., backgroundColor:)"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"UIImage background","type":"text"}],"type":"paragraph"}]}]},{"syntax":null,"type":"codeListing","code":["headerView.configure(..., backgroundImage:)"]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"UIImageURL background"}]}]}],"type":"unorderedList"},{"code":["headerView.configure(..., backgroundImageURL:)"],"type":"codeListing","syntax":null},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"MKCoordinateRegion map"}],"type":"paragraph"}]}]},{"code":["headerView.configure(..., mapCoordinateRegion:mapAnnotation:)"],"type":"codeListing","syntax":null},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"2D Barcode"}],"type":"paragraph"}]}],"type":"unorderedList"},{"c